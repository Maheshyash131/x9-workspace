{
  "expo": {
    "name": "X9 WorkSpace",
    "slug": "x9-workspace",
    "scheme": "x9workspace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-v1.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon-v1.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-v1.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.x9workspace"
    },
    "web": {
      "favicon": "./assets/icon-v1.png"
    },
    "plugins": [
      "@clerk/expo",
      "expo-router",
      "expo-secure-store"
    ]
  }
}
